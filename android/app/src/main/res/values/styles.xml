<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Use standard edit text background -->
        <item name="android:editTextBackground">@android:drawable/edit_text</item>
    </style>

    <!-- Landscape theme for tablets -->
    <style name="AppTheme.Landscape" parent="AppTheme">
        <!-- windowOrientation is deprecated in API 26+, use screenOrientation instead -->
        <item name="android:screenOrientation">sensorLandscape</item>
    </style>
</resources>
